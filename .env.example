# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it contains private credentials.

# ─── Data adapter ─────────────────────────────────────────────────────────────
# "mock" = in-memory seed data (no credentials needed)
# "google-sheets" = live Google Sheets
REPOSITORY_ADAPTER=mock

# ─── Google Service Account ───────────────────────────────────────────────────
# From the JSON key downloaded at: IAM & Admin → Service Accounts → Keys → Add Key → JSON
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# ─── Per-plant spreadsheets ───────────────────────────────────────────────────
# Spreadsheet ID from URL: https://docs.google.com/spreadsheets/d/<ID>/edit
SHEETS_ID_NMQM=
SHEETS_ID_NMXH=
SHEETS_ID_NMCT=

# ─── Shared Lô Rừng spreadsheet (managed by AppSheet) ────────────────────────
SHEETS_ID_LORUNG=

# ─── Shared Nguyên liệu spreadsheet (materials — shared by all plants) ────────
SHEETS_ID_NGUYEN_LIEU=
DRIVE_FOLDER_NGUYEN_LIEU=

# ─── Google Drive folders (photo uploads) ─────────────────────────────────────
# Folder ID from URL: https://drive.google.com/drive/folders/<ID>
DRIVE_FOLDER_NMQM=
DRIVE_FOLDER_NMXH=
DRIVE_FOLDER_NMCT=

# ─── Google Maps (client-side) ────────────────────────────────────────────────
# Enable "Maps JavaScript API" in Google Cloud Console, then create an API key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─── App defaults ─────────────────────────────────────────────────────────────
DEFAULT_PLANT_ID=NMQM
